generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ShortLink {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  url       String
  createdAt DateTime @default(now())
}
